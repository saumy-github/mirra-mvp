# ── Mirra Standalone Frontend ────────────────────────────────────────
# Copy this file to .env.development before running the app — Vite loads
# .env.development automatically in dev mode (`npm run dev`). Values here
# are safe defaults for local development; nothing in this file is secret.
# If a future var ever holds a real secret, it must NOT go in .env.example
# — only in your local, gitignored .env.development.
# Origin this app is served from (dev default)
VITE_RUNTIME_ORIGIN=http://localhost:3000

# Real backend base URL. Unused while VITE_INTEGRATION_MODE=mock, since the
# app talks to its own in-process mock instead.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Auth provider: "mock" (dev, in-process) | "live" (real backend auth)
VITE_AUTH_PROVIDER=mock

# Engine modes: "demo" (simulated, clearly labelled in the UI) | "live"
VITE_AVATAR_ENGINE_MODE=demo
VITE_TRYON_ENGINE_MODE=demo

# Data integration: "mock" (in-process fixtures behind the same API contract)
#                   "live" (real backend at VITE_API_BASE_URL)
VITE_INTEGRATION_MODE=mock

VITE_ANALYTICS_ENABLED=true

# App metadata attached to analytics events
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development
