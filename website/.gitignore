# Dependencies
node_modules/

# Build output
dist/
build/
.vite/

# Env files — real values live here, never commit
.env
.env.local
.env.*.local
.env.development
.env.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Editor / OS
# .vscode/settings.json and extensions.json are intentionally committed —
# shared format-on-save + recommended-extensions config, not personal prefs.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Test artifacts
coverage/
playwright-report/
test-results/
