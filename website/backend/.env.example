# Copy to .env and adjust. Every setting has a dev default in src/config.py,
# so a missing .env still boots against local Mongo.

# MongoDB — same mirratest database the CLO pipeline already uses
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=mirratest

# Auth (backend-implementation-plan.md, Phase 0 item 1)
ACCESS_TOKEN_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false

# CORS — comma-separated origins; default is the Vite dev server (port 3000)
CORS_ORIGINS=http://localhost:3000

# CLO3D engine seams: demo | live
AVATAR_ENGINE_MODE=demo
TRYON_ENGINE_MODE=demo

# Capture photo storage directory (relative to website/backend/)
UPLOADS_DIR=uploads
