# Copy this file to .env and fill in the values for your machine.
# Only uncomment and set the block that matches your OS.

# ── Shared values (required on all platforms) ────────────────────────────────
BUILD_CONFIG=Release
CMAKE_EXE=


# ══════════════════════════════════════════════════════════════════════════════
# WINDOWS — uncomment this block when building on Windows
# ══════════════════════════════════════════════════════════════════════════════
# PLUGIN_PLATFORM=windows
# CLO_SDK_PATH=C:/path/to/CLO_SDK_root
# CLO_PLUGINS_DIR=C:/path/to/CLO Standalone OnlineAuth/plugins
# CMAKE_GENERATOR=Visual Studio 17 2022
# CMAKE_ARCH=x64
#
# Vault — stores every installed build so you can roll back.
# Must be OUTSIDE the repo. CLO never loads from here.
# Only one versioned DLL lives in CLO_PLUGINS_DIR at a time.
# CLO_PLUGIN_VAULT_DIR=C:/Program Files/CLO Standalone OnlineAuth/plugins/mirra-vault


# ══════════════════════════════════════════════════════════════════════════════
# macOS — uncomment this block when building on macOS
# ══════════════════════════════════════════════════════════════════════════════
# PLUGIN_PLATFORM=mac
#
# Vault — stores every installed build so you can roll back.
# Must be OUTSIDE the repo. CLO never loads from here.
# CLO_PLUGIN_VAULT_DIR=/Users/yourname/Documents/CLO/Plugins/mirra-vault
#
# CLO SDK — download from CLO developer portal, match your CLO version exactly.
# CLO_SDK_PATH=/Users/yourname/Downloads/CLO_SDK_vYYYY.X.XXX_Mac
#
# Plugin install destination — CLO loads plugins from this folder.
# CLO_PLUGINS_DIR=/Users/yourname/Documents/CLO/Plugins
#
# Qt 5 — required to build the plugin. Two common install paths:
#
#   Option A: Homebrew (recommended, Apple Silicon)
#     brew install qt@5
#   CMAKE_PREFIX_PATH=/opt/homebrew/opt/qt@5
#   Qt5_DIR=/opt/homebrew/opt/qt@5/lib/cmake/Qt5
#
#   Option B: Qt online installer
#   CMAKE_PREFIX_PATH=/Users/yourname/Qt/5.15.16/macos
#   Qt5_DIR=/Users/yourname/Qt/5.15.16/macos/lib/cmake/Qt5
#
# Architecture — arm64 for Apple Silicon (M1/M2/M3/M4), x86_64 for Intel Mac.
# CMAKE_OSX_ARCHITECTURES=arm64
