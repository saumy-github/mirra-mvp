# Copy this file to .env and adjust the values for your machine.

# Shared values
PLUGIN_PLATFORM=windows
BUILD_CONFIG=Release
CLO_SDK_PATH=C:/path/to/CLO_SDK_root

# Shared optional values
CMAKE_EXE=

# Windows-only values
CMAKE_GENERATOR=Visual Studio 18 2026
CMAKE_ARCH=x64
CLO_PLUGINS_DIR=C:/path/to/CLO/plugins

# macOS-only values
# - Set PLUGIN_PLATFORM=mac when building on macOS.
# - Set CLO_SDK_PATH to your macOS CLO SDK root.
# - Set CLO_PLUGINS_DIR when using --install. A common value is:
#   /Users/yourname/Documents/CLO/Plugins
# - Set either CMAKE_PREFIX_PATH or Qt5_DIR if CMake does not find Qt5 automatically.
# - Override CMAKE_OSX_ARCHITECTURES if you are not building for Apple Silicon.
# - CMAKE_GENERATOR and CMAKE_ARCH are usually not needed on macOS.
#
# Example macOS values:
# PLUGIN_PLATFORM=mac
# CLO_SDK_PATH=/Users/yourname/Downloads/CLO_SDK_v2025.2.368_Mac
# CLO_PLUGINS_DIR=/Users/yourname/Documents/CLO/Plugins
# CMAKE_PREFIX_PATH=/Users/yourname/Qt/5.15.16/macos
# Qt5_DIR=/Users/yourname/Qt/5.15.16/macos/lib/cmake/Qt5
# CMAKE_OSX_ARCHITECTURES=arm64
CMAKE_PREFIX_PATH=
Qt5_DIR=
CMAKE_OSX_ARCHITECTURES=arm64
